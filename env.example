NP_SITE_ROOT=/srv/np-site
PRIMARY_DOMAIN=xn--e1afmkfd.xn--p1ai
WWW_DOMAIN=www.xn--e1afmkfd.xn--p1ai
NGINX_CLIENT_MAX_BODY_SIZE=300m
CERTBOT_EMAIL=admin@example.com

ADMIN_URL=replace-with-a-long-random-admin-url
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-at-least-50-chars
DJANGO_ALLOWED_HOSTS=xn--e1afmkfd.xn--p1ai,www.xn--e1afmkfd.xn--p1ai
DJANGO_CSRF_TRUSTED_ORIGINS=https://xn--e1afmkfd.xn--p1ai,https://www.xn--e1afmkfd.xn--p1ai
DJANGO_HEALTHCHECK_HOST=xn--e1afmkfd.xn--p1ai

DJANGO_SQLITE_PATH=/app/data/db.sqlite3
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=2592000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_USE_X_FORWARDED_HOST=false
DJANGO_LOG_LEVEL=INFO
FIELD_ENCRYPTION_KEYS=v1:replace-with-a-fernet-key

PROBLEM_PHOTO_MAX_FILES=5
PROBLEM_PHOTO_MAX_SIZE=10485760
PROBLEM_IMAGE_ALLOWED_FORMATS=JPEG,PNG,WEBP
PROBLEM_IMAGE_MAX_WIDTH=1920
PROBLEM_IMAGE_MAX_HEIGHT=1920
PROBLEM_IMAGE_MAX_PIXELS=16000000
PROBLEM_IMAGE_JPEG_QUALITY=82
PROBLEM_IMAGE_WEBP_QUALITY=82
PROBLEM_IMAGE_PNG_COMPRESS_LEVEL=9
PROBLEM_IMAGE_MIN_SAVING_BYTES=4096
PROBLEM_EVIDENCE_MAX_FILES=10
PROBLEM_EVIDENCE_MAX_SIZE=20971520
DJANGO_FILE_UPLOAD_MAX_MEMORY_SIZE=2500000
DJANGO_DATA_UPLOAD_MAX_NUMBER_FILES=25

BACKUP_RETENTION_DAYS=30
